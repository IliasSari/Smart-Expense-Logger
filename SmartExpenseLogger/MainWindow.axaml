<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SmartExpenseLogger"
        x:Class="SmartExpenseLogger.MainWindow"
        x:DataType="local:MainWindow"
        Title="Smart Expense Logger"
        Width="400" Height="450">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Register expenses" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,10"/>
    
        <ComboBox Grid.Row="1" Name="cmbCategory" ItemsSource="{Binding Categories}" 
                  PlaceholderText="Επιλέξτε Κατηγορία" HorizontalAlignment="Stretch" Margin="0,5"/>
    
        <TextBox Grid.Row="2" Name="txtDescription" PlaceholderText="Describe Output..." Margin="0,5"/>
    
        <TextBox Grid.Row="3" Name="txtAmount" PlaceholderText="Ποσό (€)..." Margin="0,5"/>
    
        <Button Grid.Row="4" Name="btnAdd" Content="Add" HorizontalAlignment="Stretch" 
                Click="OnAddButtonClick" Margin="0,10"/>
    
        <ListBox Grid.Row="5" ItemsSource="{Binding MyExpenses}" Margin="0,5"/>
    
        <TextBlock Grid.Row="6" Name="lblTotal" Text="Total: 0€" FontWeight="Bold" Margin="0,10,0,0"/>
    </Grid>
</Window>