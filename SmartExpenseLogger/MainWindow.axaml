<StackPanel Orientation="Vertical" Spacing="10" Margin="20">
    
    <TextBlock Text="Register Expenses" FontSize="20" HorizontalAlignment="Center"/>
    <TextBox Name="txtDescription" Watermark="Output Description..."/>
    <TextBox Name="txtAmount" Watermark="Amount (€)..."/>
    <Button Name="btnAdd" Content="Add" HorizontalAlignment="Stretch"/>
     
</StackPanel>